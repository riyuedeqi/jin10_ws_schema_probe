[Unit]
Description=Jin10 QQ group AI mention bot
After=network-online.target jin10-qq-bot.service
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/jin10_ws_schema_probe
ExecStart=/home/ubuntu/jin10_ws_schema_probe/.venv/bin/python /home/ubuntu/jin10_ws_schema_probe/ai_chat_bot.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
